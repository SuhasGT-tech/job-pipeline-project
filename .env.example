# Copy this file to .env and fill in your real values. Never commit .env.
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Full Postgres connection string from Supabase Project Settings -> Database
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# Same Supabase credentials, broken out for dbt's profiles.yml
SUPABASE_HOST=your-project-ref.supabase.co
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_password
SUPABASE_DBNAME=postgres

# Gmail digest settings — see send_digest.py
GMAIL_ADDRESS=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your16characterapppassword
DIGEST_TO_EMAIL=your_gmail_address@gmail.com
QA_DIGEST_TO_EMAIL=your_friends_email@gmail.com